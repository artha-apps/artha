# Dependencies
node_modules/
.pnp
.pnp.js

# Build outputs
packages/*/dist/
dist/
*.tsbuildinfo

# Electron builder
release/
# but keep the landing site's API route source files
!landing/app/api/release/

# Environment
.env
.env.local
.env.*.local

# Secrets / signing keys — NEVER commit (license-signing key, Apple cert, etc.)
*.pem
*.p12
*.key
.artha-license-key.pem

# Comp/beta license records — hold live license keys + customer emails. NEVER commit.
demo_beta_test.md

# Artha runtime data (never commit user data)
artha-data/
*.artha.db
*.artha.db-shm
*.artha.db-wal

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/settings.json
.idea/
*.swp

# Claude Code local harness state (machine-local, never commit)
.claude/settings.local.json
.claude/scheduled_tasks.lock
.claude/*.lock

# Logs
*.log
npm-debug.log*

# License signing key — NEVER commit. Seller-only, lives at ~/.artha-license-key.pem.
*.pem

# LLM models (large files — use .artha/models/)
*.gguf
*.bin
models/
