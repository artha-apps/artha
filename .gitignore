# Dependencies
node_modules/
.pnp
.pnp.js

# Build outputs
packages/*/dist/
dist/
*.tsbuildinfo

# Electron builder
release/
# but keep the landing site's API route source files
!landing/app/api/release/

# Environment
.env
.env.local
.env.*.local

# Secrets / signing keys — NEVER commit (license-signing key, Apple cert, etc.)
*.pem
*.p12
*.pfx
*.key
.artha-license-key.pem
# Windows Authenticode test cert (generated by scripts/gen-windows-test-cert.mjs)
.artha-win-signing/

# Comp/beta license records — hold live license keys + customer emails. NEVER commit.
demo_beta_test.md

# Internal strategy / spec / dev-state docs — kept private (moved to
# ../artha-internal-docs). Public-facing legal/marketing copy
# (docs/gtm/{privacy_policy,terms_of_service,pricing_page_copy}.md), README,
# CONTRIBUTING, getting-started, user-guide, and architecture stay tracked.
Artha_PRD_*.docx
Artha_Competitive_Analysis.docx
Artha_Features_vs_Cowork.docx
Artha_Functional_Reference.docx
REQUIREMENTS.md
docs/Artha_PRD_*.md
docs/Artha_PRD_*.html
docs/requirement.md
docs/gtm/onboarding/
docs/gtm/soc2_readiness_checklist.md
docs/idea-inbox-mvp-roadmap.md
docs/roadmap/
docs/feature-deep-dive.md
docs/DEVELOPMENT_LOG.md
docs/PROGRESS.md
docs/site-map.md

# Artha runtime data (never commit user data)
artha-data/
*.artha.db
*.artha.db-shm
*.artha.db-wal

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/settings.json
.idea/
*.swp

# Claude Code local harness state (machine-local, never commit)
.claude/settings.local.json
.claude/scheduled_tasks.lock
.claude/*.lock

# Logs
*.log
npm-debug.log*

# License signing key — NEVER commit. Seller-only, lives at ~/.artha-license-key.pem.
*.pem

# LLM models (large files — use .artha/models/)
*.gguf
*.bin
models/

# Playwright MCP session artifacts
.playwright-mcp/
